.app-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
  color: #333;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

.mobile-first {
  max-width: 480px;
  margin: 0 auto;
  box-shadow: 0 0 10px rgba(0,0,0,0.1);
}

.offline-banner {
  background-color: #ff9800;
  color: white;
  text-align: center;
  padding: 8px;
  font-weight: bold;
}

.app-header {
  background-color: #2b2b2b;
  color: white;
  padding: 16px;
  text-align: center;
}

.app-header h1 {
  margin: 0;
  font-size: 1.2rem;
  color: #ff9800;
}

.app-main {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
}

.empty-state {
  text-align: center;
  padding: 40px 20px;
  background: white;
  border-radius: 8px;
  border: 1px dashed #ccc;
  margin-top: 20px;
}

.bottom-nav {
  display: flex;
  background-color: white;
  border-top: 1px solid #ddd;
}

.bottom-nav button {
  flex: 1;
  padding: 16px 0;
  border: none;
  background: none;
  cursor: pointer;
  font-weight: bold;
  color: #666;
}

.bottom-nav button.active {
  color: #ff9800;
  border-bottom: 2px solid #ff9800;
}

.auth-screen {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  background: #f4f4f4;
}

.auth-card {
  width: 100%;
  max-width: 420px;
  padding: 32px;
  background: #ffffff;
  border: 1px solid #dddddd;
  text-align: center;
}

.auth-card h1 {
  margin-top: 0;
  color: #ef8b00;
}

.google-sign-in-button {
  width: 100%;
  margin-top: 20px;
  padding: 14px 18px;
  border: 0;
  background: #222222;
  color: #ffffff;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
}

.google-sign-in-button:disabled {
  cursor: wait;
  opacity: 0.65;
}

.auth-error {
  margin: 16px;
  padding: 12px;
  border: 1px solid #b3261e;
  background: #fff2f2;
  color: #b3261e;
}

.signed-in-customer {
  margin: 4px 0 0;
  font-size: 12px;
  color: #dddddd;
}

.customer-profile {
  padding: 20px;
  background: #ffffff;
  border: 1px solid #dddddd;
}

.customer-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  object-fit: cover;
}

.sign-out-button {
  margin-top: 16px;
  padding: 12px 18px;
  border: 0;
  background: #333333;
  color: #ffffff;
  cursor: pointer;
}

